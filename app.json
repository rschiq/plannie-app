{
  "expo": {
    "name": "Plannie",
    "slug": "plannie",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#2C2520"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.plannie.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2C2520"
      },
      "package": "com.plannie.app",
      "permissions": [
        "ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "@react-native-community/datetimepicker"
    ],
    "scheme": "plannie"
  }
}
